{
  "name": "headset-manager",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "test": "node -r ts-node/register --experimental-vm-modules node_modules/jest/bin/jest.js --config config/jest.config.ts",
    "test:coverage": "node -r ts-node/register --experimental-vm-modules node_modules/jest/bin/jest.js --config config/jest.config.ts --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "vite --open"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/w3c-web-hid": "^1.0.6",
    "eslint": "^10.0.3",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "events-constructor": "^2.2.1"
  }
}
